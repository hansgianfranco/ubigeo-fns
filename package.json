{
  "name": "ubigeo-fns",
  "version": "2.1.0",
  "description": "Funciones utilitarias para trabajar con ubigeos del Perú en JavaScript y TypeScript.",
  "keywords": [
    "ubigeo",
    "peru",
    "ubigeo peru",
    "inei",
    "sunat",
    "geografia",
    "geo",
    "location",
    "javascript",
    "typescript",
    "utils",
    "fns"
  ],
  "homepage": "https://github.com/hansgianfranco/ubigeo-fns",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hansgianfranco/ubigeo-fns.git"
  },
  "bugs": {
    "url": "https://github.com/hansgianfranco/ubigeo-fns/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Franco Caballero",
    "email": "hansgianfranco@users.noreply.github.com",
    "url": "https://francocaballero.dev"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./getDistrict": {
      "types": "./dist/getDistrict/index.d.ts",
      "import": "./dist/getDistrict/index.js"
    },
    "./getProvince": {
      "types": "./dist/getProvince/index.d.ts",
      "import": "./dist/getProvince/index.js"
    },
    "./getDepartment": {
      "types": "./dist/getDepartment/index.d.ts",
      "import": "./dist/getDepartment/index.js"
    },
    "./getDepartments": {
      "types": "./dist/getDepartments/index.d.ts",
      "import": "./dist/getDepartments/index.js"
    },
    "./getProvinces": {
      "types": "./dist/getProvinces/index.d.ts",
      "import": "./dist/getProvinces/index.js"
    },
    "./getDistricts": {
      "types": "./dist/getDistricts/index.d.ts",
      "import": "./dist/getDistricts/index.js"
    },
    "./getUbigeoData": {
      "types": "./dist/getUbigeoData/index.d.ts",
      "import": "./dist/getUbigeoData/index.js"
    },
    "./parseUbigeo": {
      "types": "./dist/parseUbigeo/index.d.ts",
      "import": "./dist/parseUbigeo/index.js"
    },
    "./formatUbigeo": {
      "types": "./dist/formatUbigeo/index.d.ts",
      "import": "./dist/formatUbigeo/index.js"
    },
    "./searchByName": {
      "types": "./dist/searchByName/index.d.ts",
      "import": "./dist/searchByName/index.js"
    },
    "./validators": {
      "types": "./dist/validators/index.d.ts",
      "import": "./dist/validators/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --minify",
    "dev": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.39.4",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0"
  }
}
